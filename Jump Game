#include <vector>
#include <algorithm>

using namespace std;

class Solution {
public:
    bool canJump(vector<int>& nums) {
        int max_reach = 0;
        int n = nums.size();
        
        for (int i = 0; i < n; ++i) {
            // If the current index is beyond our maximum reach, we can't proceed
            if (i > max_reach) {
                return false;
            }
            
            // Update the maximum reach possible
            max_reach = max(max_reach, i + nums[i]);
            
            // Optimization: If we can already reach the last index, return true
            if (max_reach >= n - 1) {
                return true;
            }
        }
        
        return true;
    }
};
