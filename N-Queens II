#include <vector>

using namespace std;

class Solution {
public:
    int totalNQueens(int n) {
        int count = 0;
        
        // Track columns and diagonals occupied by queens
        vector<bool> cols(n, false);
        vector<bool> diag1(2 * n, false); // r - c + n
        vector<bool> diag2(2 * n, false); // r + c
        
        backtrack(0, n, count, cols, diag1, diag2);
        
        return count;
    }

private:
    void backtrack(int row, int n, int& count,
                   vector<bool>& cols, vector<bool>& diag1, vector<bool>& diag2) {
        // Base case: All queens are placed successfully
        if (row == n) {
            count++;
            return;
        }
        
        for (int col = 0; col < n; ++col) {
            int d1 = row - col + n;
            int d2 = row + col;
            
            // Check if placing a queen here causes a conflict
            if (cols[col] || diag1[d1] || diag2[d2]) {
                continue;
            }
            
            // Place the queen
            cols[col] = diag1[d1] = diag2[d2] = true;
            
            // Recurse to the next row
            backtrack(row + 1, n, count, cols, diag1, diag2);
            
            // Backtrack: Remove the queen and restore states
            cols[col] = diag1[d1] = diag2[d2] = false;
        }
    }
};
